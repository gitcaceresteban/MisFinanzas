{
  "name": "motor-financiero",
  "version": "1.0.0",
  "private": true,
  "description": "Build de estilos (Tailwind) para el Motor Financiero. Solo se necesita si editas las plantillas o el diseño.",
  "scripts": {
    "build:css": "tailwindcss -c ./tailwind.config.js -i ./static/css/input.css -o ./static/css/app.css --minify",
    "watch:css": "tailwindcss -c ./tailwind.config.js -i ./static/css/input.css -o ./static/css/app.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17"
  }
}
