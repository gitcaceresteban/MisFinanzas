# Copia este archivo a .env y ajusta lo que necesites.
#   cp .env.example .env

# Clave para firmar sesiones (cámbiala por algo aleatorio)
SECRET_KEY=cambia-esta-clave-por-algo-aleatorio

# Servidor
HOST=0.0.0.0
PORT=5000
DEBUG=False

# Base de datos (SQLite local)
DATABASE_PATH=database/finance.db

# Token para la API REST (Telegram, Atajos de iPhone, Home Assistant)
API_TOKEN=cambia-este-token-por-uno-secreto

# Regional (Chile)
LOCALE=es_CL
CURRENCY=CLP
TIMEZONE=America/Santiago

# Backups
BACKUP_DIR=backups
BACKUP_KEEP=10

# Subidas (logos, comprobantes)
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10
